{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-buddy",
  "version": "0.1.0",
  "identifier": "com.ccbuddy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CC Buddy",
        "width": 480,
        "height": 360,
        "minWidth": 240,
        "minHeight": 200,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
